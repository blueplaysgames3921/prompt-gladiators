# AI Battle Arena — LiteLLM config for Docker Compose
# Copy this to docker/litellm_config.yaml and fill in your API keys.
# See https://docs.litellm.ai/docs/proxy/configs for full reference.

model_list:
  # ── Pollinations.ai (free, no key required for basic access)
  - model_name: pollinations/openai
    litellm_params:
      model: openai/openai
      api_base: https://text.pollinations.ai/openai
      api_key: your-pollinations-key

  # ── OpenAI
  # - model_name: gpt-4o
  #   litellm_params:
  #     model: gpt-4o
  #     api_key: sk-...

  # - model_name: gpt-4o-mini
  #   litellm_params:
  #     model: gpt-4o-mini
  #     api_key: sk-...

  # - model_name: o3-mini
  #   litellm_params:
  #     model: o3-mini
  #     api_key: sk-...

  # ── Google Gemini
  # - model_name: gemini-2.0-flash
  #   litellm_params:
  #     model: gemini/gemini-2.0-flash
  #     api_key: your-google-key

  # ── Groq (fast open-source inference)
  # - model_name: llama-3-70b
  #   litellm_params:
  #     model: groq/llama-3-70b-8192
  #     api_key: your-groq-key

  # ── xAI Grok
  # - model_name: grok-2
  #   litellm_params:
  #     model: xai/grok-2-latest
  #     api_key: your-xai-key

  # ── Local Ollama (must be running on host)
  # - model_name: llama3-local
  #   litellm_params:
  #     model: ollama/llama3
  #     api_base: http://host.docker.internal:11434

litellm_settings:
  drop_params: true
  set_verbose: false
  request_timeout: 120
