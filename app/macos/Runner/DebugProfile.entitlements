<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Outbound network access: relay server, LiteLLM, model APIs -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Inbound connections: LiteLLM sidecar listens on localhost -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Allow spawning child processes (LiteLLM sidecar) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- App Sandbox — must be false to spawn LiteLLM subprocess -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
