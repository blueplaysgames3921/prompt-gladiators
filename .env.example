# Prompt Gladiators — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# ─── Relay Server ─────────────────────────────────────────────────────────────
# Port the relay WebSocket server listens on
RELAY_PORT=8080

# Optional bearer token to secure the relay.
# Set this if you're exposing the relay to the internet.
# Leave empty for no auth (local/LAN use).
RELAY_AUTH_TOKEN=

# ─── LiteLLM (Docker only) ────────────────────────────────────────────────────
LITELLM_PORT=4000
