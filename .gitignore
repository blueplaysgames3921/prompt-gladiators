# ─── Flutter / Dart ───────────────────────────────────────────────────────────
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/build/
app/.fvm/

# Generated files — commit the .g.dart and .freezed.dart only if you want
# reproducible builds without running build_runner. Otherwise add them here:
# app/lib/**/*.g.dart
# app/lib/**/*.freezed.dart

# ─── Go ───────────────────────────────────────────────────────────────────────
relay/relay              # built binary
relay/*.test
relay/coverage.out

# ─── LiteLLM / Secrets ────────────────────────────────────────────────────────
docker/litellm_config.yaml     # contains API keys — use .example as template
litellm-sidecar/configs/*.yaml  # same

# ─── Environment ─────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ─── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.iml

# ─── Docker ───────────────────────────────────────────────────────────────────
docker/.env
